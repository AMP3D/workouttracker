{
  "name": "workouttracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "deploy": "tsc -b && vite build && gh-pages -d dist -m \"$(git log -1 --format=%s)\""
  },
  "dependencies": {
    "@preact/signals-react": "^3.10.2",
    "idb": "^8.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/signals-react-transform": "^0.8.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
